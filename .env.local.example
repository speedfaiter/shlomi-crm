# ─── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── WhatsApp Business Cloud API ──────────────────────
# Get from: developers.facebook.com → WhatsApp product
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# ─── Facebook Messenger + Instagram ──────────────────
# Same Meta app, different product (Messenger)
MESSENGER_VERIFY_TOKEN=your-random-verify-token
MESSENGER_PAGE_ACCESS_TOKEN=your-page-access-token

# ─── Cron (optional) ─────────────────────────────────
CRON_SECRET=your-random-secret-here

# ─── WhatsApp Direct Links ───────────────────────────
# No API keys needed for wa.me links — they work automatically!
